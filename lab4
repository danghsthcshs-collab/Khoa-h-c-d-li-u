# bài 1
-- Tạo bảng Khách hàng
CREATE TABLE customers (
    customer_id SERIAL PRIMARY KEY,
    full_name VARCHAR(100) NOT NULL,
    phone_number VARCHAR(15)
);

-- Tạo bảng Sản phẩm
CREATE TABLE products (
    product_id SERIAL PRIMARY KEY,
    product_name VARCHAR(100) NOT NULL,
    price DECIMAL(10, 2) CHECK (price > 0) -- Ràng buộc giá > 0
);

-- Tạo bảng Đơn hàng
CREATE TABLE orders (
    order_id SERIAL PRIMARY KEY,
    customer_id INT REFERENCES customers(customer_id),
    order_date DATE DEFAULT CURRENT_DATE
);



# bài 2
CREATE TABLE suppliers (
    supplier_id INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    supplier_name VARCHAR(255) NOT NULL,
    contact_phone VARCHAR(15) UNIQUE
);


# bài 3
-- 1. Thêm cột email vào bảng suppliers
ALTER TABLE suppliers ADD COLUMN email VARCHAR(100);

-- 2. Thêm cột supplier_id vào bảng products và tạo khóa ngoại
ALTER TABLE products ADD COLUMN supplier_id INT;
ALTER TABLE products 
ADD CONSTRAINT fk_supplier 
FOREIGN KEY (supplier_id) REFERENCES suppliers(supplier_id);


